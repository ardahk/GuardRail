# GuardRail local environment template
# Copy to .env and adjust as needed.

# Backend
API_HOST=127.0.0.1
API_PORT=8000
VITE_API_BASE=http://127.0.0.1:8000
VITE_WS_BASE=ws://127.0.0.1:8000

# OpenAI (judge, attacker, mitigation)
OPENAI_API_KEY=replace-me
SECURITY_JUDGE_MODEL=gpt-5.4-mini
ATTACKER_MODEL=gpt-5.4-mini

# Demo target
DEMO_TARGET_URL=http://127.0.0.1:7070
# Set VICTIM_MODEL to use a real victim model (e.g. gpt-5.4-nano or gemini-2.5-flash-lite)
# If using OpenAI-compatible victim models, set OPENAI_API_KEY.
# If using Gemini victim models, set GEMINI_API_KEY.
# Leave VICTIM_MODEL empty to use keyword-matching BurritoBot for offline demos.
VICTIM_MODEL=

# Optional startup command overrides for scripts/start-local.sh
GUARDRAIL_API_START_CMD="uvicorn backend.main:app --host 127.0.0.1 --port 8000"
GUARDRAIL_WEB_START_CMD="npm run dev -- --host 127.0.0.1 --port 3000"
GUARDRAIL_DEMO_START_CMD="npm --prefix demo-target run dev"

# Playwright proxy (for browser-based target testing)
PLAYWRIGHT_PROXY_PORT=7071
GUARDRAIL_PROXY_START_CMD="npm --prefix playwright-proxy run start"

# Test-mode knobs
ENABLE_INTEGRATION_TESTS=false
